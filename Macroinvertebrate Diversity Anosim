# ==============================================================================
# Combining Stream Type and Month into a single factor for community analysis
MacroGroups2025$Group <- paste(MacroGroups2025$Stream.Type, MacroGroups2025$Month, sep = "_")
group <- MacroGroups2025$Group

# Running ANOSIM based on Bray-Curtis distance
anosim_result <- anosim(bc_dist, grouping = group, permutations = 999)
summary(anosim_result)

