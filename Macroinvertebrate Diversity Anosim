# ==============================================================================
# PART 6: SIMPER (Similarity Percentages)
# ==============================================================================
# Identifying which taxa contribute most to the differences between groups

# Extraction function for top contributors
get_top_taxa <- function(simper_comp, top_n = 5) {
  df <- as.data.frame(simper_comp)
  df$Taxon <- rownames(df)
  df <- df %>%
    mutate(MoreAbundantIn = ifelse(ava > avb, "Group A", "Group B")) %>%
    arrange(desc(average)) %>%
    slice(1:top_n) %>%
    select(Taxon, MoreAbundantIn, average, ava, avb, cumsum, p)
  return(df)
}

# Run SIMPER and extract top 5 taxa per comparison
simper_summary <- summary(simper_result)
all_top_taxa <- lapply(simper_summary, get_top_taxa, top_n = 5)
all_top_taxa_combined <- do.call(rbind, Map(cbind, Comparison = names(all_top_taxa), all_top_taxa))

